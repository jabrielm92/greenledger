# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://greenledger:greenledger@localhost:5432/greenledger?schema=public"

# ============================================
# AUTH (NextAuth v5 / Auth.js)
# Set AUTH_SECRET in production. NEXTAUTH_SECRET is also supported for backwards compat.
# ============================================
AUTH_SECRET="generate-a-random-32-char-string-here"
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# OPENAI (AI)
# ============================================
OPENAI_API_KEY="sk-..."

# ============================================
# STRIPE (BILLING)
# Products and prices are auto-created on first checkout — no dashboard setup needed.
# ============================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================
# RESEND (EMAIL)
# ============================================
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@greenledger.app"

# ============================================
# QUICKBOOKS (OPTIONAL FOR MVP)
# ============================================
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
QUICKBOOKS_REDIRECT_URI="http://localhost:3000/api/quickbooks/callback"
QUICKBOOKS_ENVIRONMENT="sandbox"

# ============================================
# FILE STORAGE
# ============================================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=25

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="GreenLedger"
